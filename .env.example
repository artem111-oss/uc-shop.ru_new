# ========================================
# 🚀 UC SHOP - PRODUCTION ENVIRONMENT
# ========================================
# Скопировать этот файл в .env и заполнить значения
# cp .env.example .env
# ========================================

# ========================================
# 🏢 APPLICATION SETTINGS
# ========================================
APP_NAME="UC Shop"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_ME_WITH_php_artisan_key_generate
APP_URL=https://uc-shop.ru

# ========================================
# 🗄️ DATABASE SETTINGS
# ========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uc_shop_db
DB_USERNAME=uc_shop_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN

# ========================================
# 📧 MAIL SETTINGS
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@uc-shop.ru
MAIL_FROM_NAME="UC Shop - PUBG UC Store"

# ========================================
# 💾 CACHE SETTINGS (Redis)
# ========================================
CACHE_DRIVER=redis
CACHE_PREFIX=uc_shop

# ========================================
# 🔄 SESSION SETTINGS (Redis)
# ========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# ========================================
# 🔄 QUEUE SETTINGS (Redis)
# ========================================
QUEUE_CONNECTION=redis
QUEUE_TRIES=3
QUEUE_TIMEOUT=60

# ========================================
# 🗂️ REDIS CONFIGURATION
# ========================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1

# ========================================
# 📝 LOG SETTINGS
# ========================================
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_SLACK_WEBHOOK_URL=

# ========================================
# 🛒 BUSINESS SETTINGS
# ========================================
SHOP_NAME="UC Shop"
SHOP_CURRENCY=RUB
SHOP_TIMEZONE=Europe/Moscow

# ========================================
# 💳 PLATIMA PAYMENT GATEWAY
# ========================================
# Получить на https://platima.ru/dashboard
PLATIMA_BASE_URL=https://platima.ru
PLATIMA_PROJECT_ID=YOUR_PROJECT_ID_12345
PLATIMA_API_KEY_PROJECT=YOUR_API_KEY_PROJECT_abcdef123456
PLATIMA_SECRET_KEY=YOUR_SECRET_KEY_xyz789uvw
PLATIMA_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_for_validation

# ========================================
# 🎮 PUBG API INTEGRATION
# ========================================
# Получить на https://developer.pubg.com/
PUBG_API_BASE_URL=https://api.pubg.com/v1
PUBG_API_KEY=YOUR_PUBG_API_KEY_from_developer_console
PUBG_DELIVERY_TIMEOUT=60
PUBG_DELIVERY_RETRIES=3
PUBG_DELIVERY_BACKOFF_MS=500

# ========================================
# 📱 TELEGRAM BOT INTEGRATION
# ========================================
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
TELEGRAM_SUPPORT_CHAT_ID=YOUR_SUPPORT_GROUP_CHAT_ID
TELEGRAM_ADMIN_CHAT_ID=YOUR_PERSONAL_CHAT_ID

# ========================================
# 🔒 SECURITY SETTINGS
# ========================================
CORS_ALLOWED_ORIGINS=https://uc-shop.ru,https://www.uc-shop.ru
CSRF_ENABLED=true
RATE_LIMIT_ORDERS=10
RATE_LIMIT_PAYMENTS=20
RATE_LIMIT_CONTACT_FORM=5
RATE_LIMIT_WEBHOOK=100

# ========================================
# 🚀 PERFORMANCE SETTINGS
# ========================================
DB_QUERY_LOG=false
CACHE_OPTIMIZATION_ENABLED=true
OPCACHE_ENABLED=true
ASSET_COMPRESSION=true
GZIP_COMPRESSION=true

# ========================================
# AWS S3 (Optional for storage)
# ========================================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================================
# 🌐 LOCALIZATION
# ========================================
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
TIMEZONE=Europe/Moscow

# ========================================
# IMPORTANT - NEVER COMMIT IN GIT!
# ========================================
# - Add .env to .gitignore
# - Use different .env files for different environments:
#   .env (production)
#   .env.staging (staging)
#   .env.testing (testing)
# ========================================

VITE_APP_NAME="${APP_NAME}"
