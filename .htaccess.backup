<IfModule mod_rewrite.c>
  RewriteEngine On
  
  	# редирект с ucshop.pro на основной домен
  	RewriteCond %{HTTP_HOST} ^ucshop.pro$ [OR,NC]
	RewriteCond %{HTTP_HOST} ^www.ucshop.pro$ [NC]
	RewriteRule ^(.*)$ https://uc-shop.ru/$1 [R=301,L]
    
    # редирект с ucshop.one на основной домен
    RewriteCond %{HTTP_HOST} ^ucshop.one$ [OR,NC]
	RewriteCond %{HTTP_HOST} ^www.ucshop.one$ [NC]
	RewriteRule ^(.*)$ https://uc-shop.ru/$1 [R=301,L]
    
    # редирект с ucshop.pro на основной домен
  	RewriteCond %{HTTP_HOST} ^ucshop.fun$ [OR,NC]
	RewriteCond %{HTTP_HOST} ^www.ucshop.fun$ [NC]
	RewriteRule ^(.*)$ https://uc-shop.ru/$1 [R=301,L]
    
    # редирект с юсшоп.рф
    RewriteCond %{HTTP_HOST} ^xn--n1ace2a2a.xn--p1ai$ [OR,NC]
	RewriteCond %{HTTP_HOST} ^www.xn--n1ace2a2a.xn--p1ai$ [NC]
	RewriteRule ^(.*)$ https://uc-shop.ru/$1 [R=301,L]
    
    

  RewriteRule ^(.*)$ public/$1 [L]
  
</IfModule>
